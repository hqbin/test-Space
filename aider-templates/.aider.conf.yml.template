##########################################################
# Aider Config Template
# Copy to project root and rename to .aider.conf.yml
# Modify sections marked with [CUSTOMIZE] based on your project
# Full options: https://aider.chat/docs/config/aider_conf.html
##########################################################

# ====================
# Model Config [CUSTOMIZE]
# ====================

# Main model selection
# Recommendations:
#   - claude-3-7-sonnet-20250219  (strong editing)
#   - gpt-4o                      (fast)
#   - deepseek/deepseek-chat      (cost-effective)
#   - o3-mini                     (strong reasoning)
model: claude-3-7-sonnet-20250219

# Weak model (for commit messages and history summary)
weak-model: claude-3-5-haiku-20241022

# Editor model (dedicated for code editing, default same as main)
# editor-model: claude-3-7-sonnet-20250219

# Enable architect mode (plan before editing, good for complex refactoring)
architect: false

# API timeout (seconds)
timeout: 120

# ====================
# Project Convention Files [CUSTOMIZE]
# ====================

# Auto loaded read-only convention files
# These files are loaded into context but not modified by Aider
read:
  - CONVENTIONS.md
  # - README.md
  # - docs/architecture.md

# ====================
# Git Config
# ====================

git: true
gitignore: true

# Auto commit (suggest false, manually commit after review)
auto-commits: false
dirty-commits: false

# Committer info annotation
attribute-author: true
attribute-committer: true
attribute-co-authored-by: true

# Skip pre-commit hooks
git-commit-verify: false

# ====================
# Code Quality [CUSTOMIZE]
# ====================

# Auto lint after changes
auto-lint: true

# Lint commands (configure based on tech stack)
lint-cmd:
  # JavaScript/TypeScript/Vue
  - "typescript: npm run build"
  - "vue: npm run build"
  # Python
  # - "python: python -m py_compile"
  # - "python: flake8"
  # Rust
  # - "rust: cargo check"
  # - "rust: cargo clippy"
  # Go
  # - "go: go build ./..."
  # Java
  # - "java: ./mvnw compile"

# Auto test after changes
auto-test: false

# Test command
# test-cmd: npm test

# ====================
# Output and Interaction
# ====================

dark-mode: true
code-theme: monokai
stream: true
show-diffs: true
suggest-shell-commands: true
multiline: false
notifications: false

# ====================
# Cache and Performance
# ====================

cache-prompts: true
cache-keepalive-pings: 3
map-refresh: auto

# ====================
# History
# ====================

restore-chat-history: true
chat-history-file: .aider.chat.history.md
input-history-file: .aider.input.history

# ====================
# File Handling
# ====================

encoding: utf-8
line-endings: platform
aiderignore: .aiderignore
add-gitignore-files: false

# ====================
# Others
# ====================

chat-language: zh
commit-language: zh
vim: false
detect-urls: true
disable-playwright: true
check-update: false
