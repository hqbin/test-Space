{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TestSpace",
  "version": "1.2.5",
  "identifier": "com.testspace.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TestSpace",
        "width": 1024,
        "height": 680,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": [
      "bin/scrcpy-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false,
        "installerHooks": "./windows/hooks.nsh"
      },
      "wix": {
        "enableElevatedUpdateTask": false
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
