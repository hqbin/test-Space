# 服务器配置
HOST=0.0.0.0
PORT=8080

# 数据库配置 - PostgreSQL
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# 注意：密码中的特殊字符需要URL编码 (@ -> %40, ! -> %21)

# 本地开发 - 连接服务器数据库
# DATABASE_URL=postgresql://postgres:whaletv%40admin.com%21@172.16.60.161:5432/testcase_platform

# 服务器生产 - 连接本地数据库
DATABASE_URL=postgresql://postgres:whaletv%40admin.com%21@172.16.60.161:5432/testcase_platform

# JWT配置
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS配置（多个地址用逗号分隔）
CORS_ORIGINS=http://localhost:2026,http://172.16.52.62:2026,http://172.16.60.161:2026

# 前端地址（用于钉钉通知中的跳转链接）
FRONTEND_URL=https://tms.zeasn.com

# Zmind配置
ZMIND_API_KEY=your-zmind-api-key-here
ZMIND_BASE_URL=https://zmind.whaletv.com
# 多个项目用逗号分隔
ZMIND_PROJECT_IDENTIFIERS=project1,project2

