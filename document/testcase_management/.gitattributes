# Shell 脚本强制使用 LF 换行符（Linux 执行需要）
*.sh text eol=lf

# Nginx 配置模板也强制 LF
*.conf.template text eol=lf

# Python 脚本
*.py text eol=lf

# Windows 批处理脚本保持 CRLF
*.bat text eol=crlf

# dist 目录下的文件不做换行符转换（避免跨平台 checkout 产生 phantom changes）
app/frontend/dist/** -text
app/frontend/public/adb-tool/** -text

# 其他文本文件自动处理
*.md text
*.txt text
*.json text
*.js text
*.vue text
*.css text
*.html text
*.yml text
*.yaml text
*.ini text
*.cfg text
*.env text
